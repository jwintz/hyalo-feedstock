+#if defined HAVE_IOS
+  /* iOS: use the dump_file parameter if provided.
+     If loading fails, fall back to bootstrapping from source.  */
+  int result;
+
+  if (!dump_file)
+    return argv[0];
+
+  result = pdumper_load (dump_file, argv[0]);
+
+  if (result == PDUMPER_LOAD_SUCCESS)
+    return argv[0];
+
+  /* pdmp load failed - this is expected on first run or after binary update.
+     Fall back to bootstrapping from source.  */
+  fprintf (stderr, "iOS: pdmp load failed (%s), will bootstrap from source\n",
+           dump_error_to_string (result));
+  return argv[0];
+#elif defined HAVE_ANDROID && !defined ANDROID_STUBIFY
+  /* Android: use the dump_file parameter directly if provided,
+     otherwise fall back to --dump-file argument.  */
