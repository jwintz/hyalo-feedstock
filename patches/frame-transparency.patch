+/* Override for fringe alpha set directly from Swift (bypasses
+   the async channel / lisp path for live slider updates).
+   Negative means "no override, use frame parameter".  */
+static CGFloat ns_fringe_alpha_override = -1.0;
+
+/* Forward declaration — defined later in this file.  */
+static void ns_clear_frame_area (struct frame *f, int x, int y,
+                                 int width, int height);
+
+/* Called from Swift to set fringe alpha directly and force redisplay.
+   This bypasses the async channel / lisp event loop, allowing live
+   updates during SwiftUI slider tracking.  Pass a negative value
+   to clear the override.
+
+   During event tracking (slider drag), [view display] does NOT call
+   drawRect: for layer-backed views.  We bypass NSView entirely:
+   1. lockFocus — acquire the IOSurface-backed CGContext
+   2. ns_clear_frame_area + expose_frame — re-render all glyphs
+      with the new alpha value directly into the IOSurface
+   3. unlockFocus — release the NSGraphicsContext
+   4. [[view layer] display] — flush IOSurface to VRAM  */
+/* Force a full redisplay of all NS frames, bypassing the NSView
+   display pipeline.  Renders directly into the IOSurface and flushes
+   to VRAM.  Safe to call from any context on the main thread,
+   including during event tracking (slider drag, picker click).  */
+static void
+ns_flush_all_frames (void)
+{
+  Lisp_Object tail, frame;
+  FOR_EACH_FRAME (tail, frame)
+    {
+      struct frame *f = XFRAME (frame);
+      if (FRAME_NS_P (f) && FRAME_LIVE_P (f)
+          && !FRAME_GARBAGED_P (f) && f->glyphs_initialized_p)
+        {
+          EmacsView *view = (EmacsView *)FRAME_NS_VIEW (f);
+          if (view)
+            {
+              NSRect viewRect = [view frame];
+              int w = NSWidth (viewRect);
+              int h = NSHeight (viewRect);
+
+              ns_update_begin (f);
+              ns_clear_frame_area (f, 0, 0, w, h);
+              block_input ();
+              expose_frame (f, 0, 0, w, h);
+              unblock_input ();
+              ns_update_end (f);
+              /* ns_update_end calls unlockFocus which sets
+                 setNeedsDisplay:YES but does NOT flush the IOSurface
+                 to VRAM.  Do that explicitly.  */
+              [[view layer] display];
+            }
+        }
+    }
+}
+
+__attribute__((visibility("default")))
+void
+ns_set_fringe_alpha_override (double alpha)
+{
+  ns_fringe_alpha_override = (CGFloat) alpha;
+  ns_flush_all_frames ();
+}
+
+/* Flush the IOSurface to VRAM for all NS frames without
+   re-rendering.  Used after (redisplay t) from Lisp has already
+   rendered the correct content into the IOSurface but the layer
+   display has not been serviced by the run loop yet.  */
+static void
+ns_flush_all_layers (void)
+{
+  Lisp_Object tail, frame;
+  FOR_EACH_FRAME (tail, frame)
+    {
+      struct frame *f = XFRAME (frame);
+      if (FRAME_NS_P (f) && FRAME_LIVE_P (f) && f->glyphs_initialized_p)
+        {
+          EmacsView *view = (EmacsView *)FRAME_NS_VIEW (f);
+          if (view)
+            [[view layer] display];
+        }
+    }
+}
+
+/* Force a full redisplay of all NS frames.  Exported for Swift to
+   call directly (via dlsym) when changes must be visible immediately,
+   even when the Emacs view is not the key window.
+   If FRAME_GARBAGED_P is set (e.g. after load-theme), callers must
+   run (redisplay t) from Lisp first to clear the flag and render
+   into the IOSurface, then call this to flush to VRAM.  */
+__attribute__((visibility("default")))
+void
+ns_force_redisplay (void)
+{
+  ns_flush_all_layers ();
+}
+
+/* Wake the Emacs event loop.  Posts an NSApplicationDefined event to
+   the NSApp queue, which causes [NSApp run] to return and process
+   pending I/O (including pipe process data from Swift channels).
+   Safe to call from any thread.  Exported for Swift via dlsym.  */
+__attribute__((visibility("default")))
+void
+ns_wake_emacs (void)
+{
+  NSEvent *ev = [NSEvent otherEventWithType: NSEventTypeApplicationDefined
+                                   location: NSMakePoint (0, 0)
+                              modifierFlags: 0
+                                  timestamp: 0
+                               windowNumber: 0
+                                    context: nil
+                                    subtype: 0
+                                      data1: -1
+                                      data2: 0];
+  [NSApp postEvent: ev atStart: NO];
+}
