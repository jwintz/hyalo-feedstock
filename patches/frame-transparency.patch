+/* Return the effective alpha value for ELEMENT on frame F.
+   - nil                        -> 1.0 (opaque, element not enabled).
+   - t or ns-alpha-all          -> f->alpha_background.
+   - bare symbol matching       -> f->alpha_background.
+   - (ELEMENT . ALPHA) cons     -> ALPHA (float 0.0-1.0 or int 0-100).
+   - symbol not found           -> 1.0 (opaque).  */
+CGFloat
+ns_alpha_for_element (struct frame *f, Lisp_Object element)
+{
+  /* Fast path: if Swift set a fringe alpha override, use it
+     for ns-alpha-fringe without going through lisp.  */
+  if (ns_fringe_alpha_override >= 0.0 && EQ (element, Qns_alpha_fringe))
+    return ns_fringe_alpha_override;
+
+  Lisp_Object frame, elements;
+
+  XSETFRAME (frame, f);
+  elements = Fframe_parameter (frame, Qns_alpha_elements);
+
+  if (NILP (elements))
+    return 1.0;
+
+  if (EQ (elements, Qt) || EQ (elements, Qns_alpha_all))
+    return (CGFloat) f->alpha_background;
+
+  if (SYMBOLP (elements))
+    return EQ (elements, element) ? (CGFloat) f->alpha_background : 1.0;
+
+  if (CONSP (elements))
+    {
+      Lisp_Object tail;
+      for (tail = elements; CONSP (tail); tail = XCDR (tail))
+        {
+          Lisp_Object entry = XCAR (tail);
+
+          if (EQ (entry, Qns_alpha_all))
+            return (CGFloat) f->alpha_background;
+
+          if (SYMBOLP (entry) && EQ (entry, element))
+            return (CGFloat) f->alpha_background;
+
+          if (CONSP (entry) && EQ (XCAR (entry), element))
+            {
+              Lisp_Object val = XCDR (entry);
+              if (FLOATP (val))
+                {
+                  double a = XFLOAT_DATA (val);
+                  if (a < 0.0) a = 0.0;
+                  if (a > 1.0) a = 1.0;
+                  return (CGFloat) a;
+                }
+              if (FIXNUMP (val))
+                {
+                  EMACS_INT iv = XFIXNUM (val);
+                  if (iv < 0) iv = 0;
+                  if (iv > 100) iv = 100;
+                  return (CGFloat) iv / 100.0;
+                }
+              return (CGFloat) f->alpha_background;
+            }
+        }
+    }
+
+  return 1.0;
+}
+
+/* Return the effective alpha for the glyph background of FACE on
+   frame F.  Only faces whose background matches the default face get
+   transparency -- this keeps highlights visible.  */
+static CGFloat
+ns_glyph_bg_alpha (struct frame *f, struct face *face)
+{
+  CGFloat alpha = ns_alpha_for_element (f, Qns_alpha_glyphs);
+  if (alpha >= 1.0)
+    return 1.0;
+  struct face *default_face = FRAME_DEFAULT_FACE (f);
+  if (!default_face || !face)
+    return 1.0;
+  if (face->background != default_face->background)
+    return 1.0;
+  return alpha;
+}
