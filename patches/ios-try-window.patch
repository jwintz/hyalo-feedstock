diff --git a/src/xdisp.c b/src/xdisp.c
index 9208e13..58f6602 100644
--- a/src/xdisp.c
+++ b/src/xdisp.c
@@ -21476,6 +21476,21 @@ redisplay_window (Lisp_Object window, bool just_this_one_p)
 try_window (Lisp_Object window, struct text_pos pos, int flags)
 {
   struct window *w = XWINDOW (window);
+#ifdef HAVE_IOS
+  /* On iOS during early startup, the window's buffer may not be
+     fully initialized for bidi processing.  Return early if the
+     buffer content is invalid to prevent crashes in bidi_paragraph_init.  */
+  {
+    struct buffer *b = XBUFFER (w->contents);
+    struct frame *frame = XFRAME (w->frame);
+    if (FRAME_IOS_P (frame) || FRAME_INITIAL_P (frame))
+      {
+        if (!BUFFER_LIVE_P (b) || BUF_BEGV (b) >= BUF_ZV (b)
+            || BUF_BEGV_BYTE (b) >= BUF_ZV_BYTE (b))
+          return 0;
+      }
+  }
+#endif
   struct it it;
   struct glyph_row *last_text_row = NULL;
   struct frame *f = XFRAME (w->frame);
