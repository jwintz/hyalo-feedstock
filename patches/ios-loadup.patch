diff --git a/lisp/loadup.el b/lisp/loadup.el
index 7178639..ff7c37a 100644
--- a/lisp/loadup.el
+++ b/lisp/loadup.el
@@ -317,6 +317,20 @@
       (load "term/common-win")
       (load "term/haiku-win")))
 
+(if (featurep 'ios)
+    (progn
+      (load "ls-lisp")
+      (load "touch-screen")
+      (load "term/common-win")
+      (load "term/ios-win")))
+
+;; Debug iOS path variables before elisp-mode.el (which can fail with macro expansion errors)
+(when (featurep 'ios)
+  (message "iOS DEBUG: invocation-directory=%s invocation-name=%s default-directory=%s"
+           (or invocation-directory "(nil)")
+           (or invocation-name "(nil)")
+           (or default-directory "(nil)")))
+
 (if (featurep 'android)
     (progn
       (load "ls-lisp")
@@ -587,6 +601,30 @@
 ;; Make sure we will attempt bidi reordering henceforth.
 (setq redisplay--inhibit-bidi nil)
 
+(if (featurep 'ios)
+    ;; iOS pdmp saving: similar to Android.
+    ;; On first run (no existing dump), save emacs-<fingerprint>.pdmp to HOME.
+    ;; Subsequent runs find this file and load it (fast startup).
+    (when (not noninteractive)
+      (let ((dump-file-name (format "%semacs-%s.pdmp"
+                                    (file-name-as-directory "~")
+                                    pdumper-fingerprint))
+            (dump-temp-file-name (format "%s~emacs-%s.pdmp"
+                                         (file-name-as-directory "~")
+                                         pdumper-fingerprint)))
+        (unless (pdumper-stats)
+          ;; Not loaded from a dump - create one for next time
+          (message "iOS: Creating portable dump for fast startup next time...")
+          (message "iOS: Dump file: %s" dump-file-name)
+          (condition-case err
+              (progn
+                (dump-emacs-portable dump-temp-file-name)
+                ;; Move temp file to final name atomically
+                (rename-file dump-temp-file-name dump-file-name t)
+                (message "iOS: Portable dump created successfully"))
+            (error
+             (message "iOS: Warning - dump failed: %s" err)))))))
+
 
 (if (and (eq system-type 'android)
          (featurep 'android))
