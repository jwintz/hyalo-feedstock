+#ifdef HAVE_IOS
+/* iOS implementation using CTLine for text shaping.  */
 static CFIndex
+mac_font_shape_1 (CTFontRef font, CFStringRef string,
+                  struct mac_glyph_layout *glyph_layouts, CFIndex glyph_len,
+		  enum lgstring_direction dir)
+{
+  if (!font || !string)
+    return 0;
+
+  CFMutableDictionaryRef attrs = CFDictionaryCreateMutable (
+    NULL, 1, &kCFTypeDictionaryKeyCallBacks, &kCFTypeDictionaryValueCallBacks);
+  CFDictionarySetValue (attrs, kCTFontAttributeName, font);
+  CFAttributedStringRef attrStr = CFAttributedStringCreate (NULL, string, attrs);
+  CFRelease (attrs);
+  if (!attrStr)
+    return 0;
+
+  CTLineRef line = CTLineCreateWithAttributedString (attrStr);
+  CFRelease (attrStr);
+  if (!line)
+    return 0;
+
+  CFArrayRef runs = CTLineGetGlyphRuns (line);
+  CFIndex used = 0;
+
+  for (CFIndex r = 0; r < CFArrayGetCount (runs) && used < glyph_len; r++)
+    {
+      CTRunRef run = CFArrayGetValueAtIndex (runs, r);
+      CFIndex count = CTRunGetGlyphCount (run);
+      for (CFIndex i = 0; i < count && used < glyph_len; i++)
+        {
+          CGGlyph g;
+          CGSize adv;
+          CFIndex idx;
+          CTRunGetGlyphs (run, CFRangeMake (i, 1), &g);
+          CTRunGetAdvances (run, CFRangeMake (i, 1), &adv);
+          CTRunGetStringIndices (run, CFRangeMake (i, 1), &idx);
+          glyph_layouts[used].glyph_id = g;
+          glyph_layouts[used].string_index = idx;
+          glyph_layouts[used].advance = adv.width;
+          glyph_layouts[used].advance_delta = 0;
+          glyph_layouts[used].baseline_delta = 0;
+          glyph_layouts[used].comp_range.location = idx;
+          glyph_layouts[used].comp_range.length = 1;
+          used++;
+        }
+    }
+  CFRelease (line);
+  return used;
+}
