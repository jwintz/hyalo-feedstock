 static CGColorRef
 get_cgcolor(unsigned long color)
 {
+#ifdef HAVE_IOS
+  CGFloat r = RED_FROM_ULONG (color) / 255.0;
+  CGFloat g = GREEN_FROM_ULONG (color) / 255.0;
+  CGFloat b = BLUE_FROM_ULONG (color) / 255.0;
+  CGColorSpaceRef cs = CGColorSpaceCreateDeviceRGB ();
+  CGFloat comps[] = { r, g, b, 1.0 };
+  CGColorRef cgColor = CGColorCreate (cs, comps);
+  CGColorSpaceRelease (cs);
+  return cgColor;
+#else
   NSColor *nsColor = [NSColor colorWithUnsignedLong:color];
   [nsColor set];
   CGColorSpaceRef colorSpace = [[nsColor colorSpace] CGColorSpace];
