--- a/src/Makefile.in
+++ b/src/Makefile.in
@@ -770,6 +770,18 @@ android-emacs:
 	  $(LIBEGNU_ARCHIVE)
 endif
 
+## iOS static library target
+## This creates libemacs.a for linking into the iOS app bundle
+@HAVE_IOS_TRUE@libemacs.a: $(ALLOBJS) $(LIBEGNU_ARCHIVE)
+@HAVE_IOS_TRUE@$(AM_V_GEN)rm -f $@
+@HAVE_IOS_TRUE@$(AM_V_at)$(AR) rcs $@ $(ALLOBJS)
+@HAVE_IOS_TRUE@$(AM_V_at)if test -f $(LIBEGNU_ARCHIVE); then \
+@HAVE_IOS_TRUE@  $(AR) x $(LIBEGNU_ARCHIVE); \
+@HAVE_IOS_TRUE@  $(AR) rcs $@ *.o; \
+@HAVE_IOS_TRUE@  rm -f *.o; \
+@HAVE_IOS_TRUE@fi
+@HAVE_IOS_TRUE@@echo 'Created libemacs.a for iOS'
+
