diff --git a/src/buffer.c b/src/buffer.c
index abc1234..def5678 100644
--- a/src/buffer.c
+++ b/src/buffer.c
@@ -1086,9 +1086,18 @@ reset_buffer (register struct buffer *b)
 void
 reset_buffer (register struct buffer *b)
 {
   bset_filename (b, Qnil);
   bset_file_truename (b, Qnil);
-  bset_directory (b, current_buffer ? BVAR (current_buffer, directory) : Qnil);
+  /* Set directory from current buffer, or "/" as fallback.
+     On iOS, default-directory can be nil if getcwd() fails, and
+     new buffers would inherit nil, breaking file-relative-name
+     during macro expansion.  */
+  Lisp_Object dir = current_buffer ? BVAR (current_buffer, directory) : Qnil;
+#ifdef HAVE_IOS
+  if (NILP (dir))
+    dir = build_string ("/");
+#endif
+  bset_directory (b, dir);
   b->modtime = make_timespec (0, UNKNOWN_MODTIME_NSECS);
   b->modtime_size = -1;
   XSETFASTINT (BVAR (b, save_length), 0);
