+#ifndef EMACS_IOSDISPATCH_H
+#define EMACS_IOSDISPATCH_H
+
+#ifdef HAVE_IOS
+
+#include "lisp.h"
+
+/* ==========================================================================
+   Command IDs for iOS dispatch
+   ========================================================================== */
+
+typedef enum {
+  IOS_CMD_NONE = 0,
+  IOS_CMD_EVAL = 1,
+  IOS_CMD_OPEN_FILE = 2,
+  IOS_CMD_SWITCH_BUFFER = 3,
+  IOS_CMD_KILL_BUFFER = 4,
+  IOS_CMD_FIND_FILE = 5,
+  IOS_CMD_SAVE_BUFFER = 6,
+  IOS_CMD_EXECUTE_COMMAND = 7,
+  IOS_CMD_NAVIGATOR_SELECT = 8,
+  IOS_CMD_STATUS_TAP = 9,
+  IOS_CMD_APPEARANCE_CHANGE = 10,
+  IOS_CMD_SEARCH = 11,
+  IOS_CMD_SEARCH_NAVIGATE = 12,
+  IOS_CMD_DIAGNOSTIC_NAVIGATE = 13,
+  IOS_CMD_PACKAGE_REFRESH = 14,
+  IOS_CMD_PACKAGE_UPGRADE = 15,
+  IOS_CMD_GIT_SHOW_COMMIT = 16,
+  IOS_CMD_GIT_SHOW_DIFF = 17,
+  /* Add new commands above this line */
+  IOS_CMD_MAX
+} ios_command_id;
+
+/* ==========================================================================
+   Dispatch table structure
+   ========================================================================== */
+
+typedef Lisp_Object (*ios_dispatch_handler)(Lisp_Object args);
+
+typedef struct {
+  const char *name;
+  ios_command_id command_id;
+  ios_dispatch_handler handler;
+  Lisp_Object (*elisp_func)(Lisp_Object);
+} ios_command_entry;
+
+/* ==========================================================================
+   Global dispatch table (defined in iosfns.m)
+   ========================================================================== */
+
+extern ios_command_entry *ios_dispatch_table;
+extern int ios_dispatch_count;
+extern int ios_dispatch_capacity;
+
+/* ==========================================================================
+   Function declarations
+   ========================================================================== */
+
+extern void ios_dispatch_register(ios_command_id cmd_id, const char *name,
+                                  ios_dispatch_handler handler,
+                                  Lisp_Object (*elisp_func)(Lisp_Object));
+extern Lisp_Object ios_dispatch_command(int command_id, Lisp_Object args);
+extern ios_command_entry *ios_dispatch_lookup(int command_id);
+extern void ios_dispatch_init(void);
+
+/* ==========================================================================
+   DEFUN_IOS macro
+
+   Usage:
+     DEFUN_IOS (cmd_id, "ios-open-file", Fios_open_file, Sios_open_file,
+                1, 1, 0, doc: /* Open file in Hyalo.  */)
+       (Lisp_Object filename)
+     {
+       // Function body
+     }
+
+   This macro:
+   1. Defines the standard Emacs primitive using DEFUN
+   2. Registers the function in the iOS dispatch table
+   3. Allows Swift to call this function by command ID
+   ========================================================================== */
+
+#define DEFUN_IOS(cmd_id, lname, fnname, sname, minargs, maxargs, intspec, doc) \
+  DEFUN(lname, fnname, sname, minargs, maxargs, intspec, doc); \
+  static void __attribute__((constructor)) _register_##fnname(void) { \
+    ios_dispatch_register(cmd_id, lname, NULL, fnname); \
+  } \
+  Lisp_Object fnname
+
+/* For functions that need a custom wrapper for JSON processing */
+#define DEFUN_IOS_CUSTOM(cmd_id, lname, fnname, sname, wrapper, minargs, maxargs, intspec, doc) \
+  static Lisp_Object fnname(Lisp_Object); \
+  static Lisp_Object wrapper(Lisp_Object); \
+  DEFUN(lname, fnname, sname, minargs, maxargs, intspec, doc); \
+  static void __attribute__((constructor)) _register_##fnname(void) { \
+    ios_dispatch_register(cmd_id, lname, wrapper, fnname); \
+  } \
+  Lisp_Object fnname
+
+#endif /* HAVE_IOS */
+#endif /* EMACS_IOSDISPATCH_H */
